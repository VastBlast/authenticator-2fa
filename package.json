{
  "name": "authenticator-2fa",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/build-extension.mjs",
    "build:check": "npm run check && npm run test && npm run build",
    "build:prod": "vite build --mode production && node scripts/build-extension.mjs",
    "preview": "vite preview",
    "icons": "node scripts/generate-icons.mjs",
    "store:screenshots": "npm run build && node scripts/generate-store-screenshots.mjs",
    "lint": "oxlint --type-aware",
    "check": "npm run lint && npm run test:types && svelte-check --tsconfig ./tsconfig.json",
    "test": "npm run check && vitest run",
    "test:types": "tsc -p tsconfig.test.json",
    "clean": "node scripts/clean.mjs",
    "package": "npm run clean && npm run build:prod && node scripts/package-extension.mjs"
  },
  "dependencies": {
    "@lucide/svelte": "^1.18.0",
    "qrcode": "^1.5.4",
    "zxing-wasm": "^3.1.0"
  },
  "devDependencies": {
    "@sveltejs/mcp": "^0.1.25",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.1",
    "@tsconfig/svelte": "^5.0.2",
    "@types/chrome": "^0.2.0",
    "@types/node": "^25.9.3",
    "@types/qrcode": "^1.5.6",
    "daisyui": "^5.5.23",
    "fflate": "^0.8.3",
    "oxlint": "^1.71.0",
    "oxlint-tsgolint": "^0.24.0",
    "sharp": "^0.35.1",
    "svelte": "^5.56.3",
    "svelte-check": "^4.6.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
