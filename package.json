{
  "name": "chrome-extension-sidepanel",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:check": "npm run check && npm run build",
    "build:prod": "vite build --mode production",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "clean": "rm -rf dist extension.zip",
    "package": "npm run clean && npm run build:prod && cd dist && zip -r ../extension.zip . -x \"*.map\" \"*.DS_Store\""
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tsconfig/svelte": "^5.0.2",
    "@types/node": "^25.9.3",
    "autoprefixer": "^10.4.18",
    "daisyui": "^5.5.23",
    "postcss": "^8.4.35",
    "svelte": "^5.0.0-next.68",
    "svelte-check": "^4.6.0",
    "tailwindcss": "^4.3.1",
    "tslib": "^2.7.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  },
  "dependencies": {
    "@lucide/svelte": "^1.18.0"
  }
}
