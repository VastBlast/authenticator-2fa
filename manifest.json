{
  "manifest_version": 3,
  "name": "Authenticator - 2FA",
  "short_name": "Authenticator",
  "version": "0.1.0",
  "description": "Encrypted 2FA codes for secure sign-ins.",
  "homepage_url": "https://github.com/VastBlast/authenticator-2fa",
  "action": {
    "default_title": "Open Authenticator - 2FA",
    "default_popup": "index.html"
  },
  "commands": {
    "scan-page": {
      "description": "Scan a QR code from the current page"
    }
  },
  "permissions": ["storage", "activeTab", "scripting"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
