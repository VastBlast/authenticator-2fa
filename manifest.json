{
  "manifest_version": 3,
  "name": "Authenticator",
  "version": "0.1.0",
  "description": "Encrypted two-factor authenticator codes for your browser.",
  "action": {
    "default_title": "Authenticator",
    "default_popup": "index.html"
  },
  "permissions": ["storage", "activeTab", "scripting", "tabs"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
